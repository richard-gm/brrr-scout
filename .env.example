# Copy this to .env and fill in your values.
# None of these are required to run the app — it degrades gracefully.

# Enables: AI floorplan check, legal pack analysis, deal narrative
ANTHROPIC_API_KEY=sk-ant-...

# Enables: EPC data (bedrooms, floor area, rating) per property
# Log in at https://get-energy-performance-data.communities.gov.uk/
# Go to My Account → copy your Bearer token
# EPC_API_KEY=your-bearer-token

# Optional: residential proxy for live Rightmove/Zoopla scraping
# ScraperAPI: http://scraperapi:<key>@proxy-server.scraperapi.com:8001
# Bright Data: http://<user>:<pass>@zproxy.lum-superproxy.io:22225
# SCRAPER_PROXY_URL=
